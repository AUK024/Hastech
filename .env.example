# App
APP_NAME=Hascelik Mail Automation Platform
ENV=dev
DEBUG=true
API_PREFIX=/api/v1
SECRET_KEY=change-me

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=hascelik_mail
POSTGRES_USER=hascelik
POSTGRES_PASSWORD=hascelik

# Redis/Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Microsoft Graph
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
GRAPH_CLIENT_SECRET=your-client-secret
GRAPH_SCOPE=https://graph.microsoft.com/.default
GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
GRAPH_WEBHOOK_CLIENT_STATE=
GRAPH_WEBHOOK_NOTIFICATION_URL=
GRAPH_WEBHOOK_LIFECYCLE_URL=
GRAPH_SUBSCRIPTION_EXPIRY_MINUTES=120
GRAPH_SUBSCRIPTION_RENEW_THRESHOLD_MINUTES=30
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=

# Admin access
ADMIN_USER_EMAILS=admin@hascelik.com
ADMIN_USER_DOMAINS=

# Feature flags and defaults (DB overrides these)
DEFAULT_FALLBACK_LANGUAGE=en
DEFAULT_CONFIDENCE_THRESHOLD=0.70
